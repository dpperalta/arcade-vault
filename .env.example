# Resend — envío del formulario de contacto de /acerca
#
# API key de Resend (https://resend.com/api-keys).
# Cópiala en .env.local (NO se versiona). Nunca subas el valor real al repo.
RESEND_API_KEY=

# Destino de los mensajes del formulario de contacto.
# Con el remitente de pruebas onboarding@resend.dev, este correo DEBE ser
# el email dueño de la cuenta de Resend o el envío se rechaza.
CONTACT_TO_EMAIL=
